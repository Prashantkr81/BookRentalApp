{
  "expo": {
    "name": "BookHive",
    "slug": "bookrentalapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "bookrentalapp",
    "icon": "./assets/images/favicon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bookhive.rentalapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.bookhive.rentalapp",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/favicon.png",
        "backgroundColor": "#E6F4FE"
      },
      "permissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/favicon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow BookHive to access your photos to upload book images."
        }
      ]
    ],
    "owner": "prashantkr81",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2376f601-c8f6-44c9-88e5-281c6cfdd6a8"
      }
    }
  }
}
